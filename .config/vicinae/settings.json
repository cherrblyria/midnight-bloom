// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "close_on_focus_loss": true,
   "pop_to_root_on_close": true,
   "escape_key_behavior": "",
   "favicon_service": "google",
   "keybinding": "default",
   "font": {
      "normal": {
         "family": "CaskaydiaCove Nerd Font Propo",
         "size": 10.5
      }
   },
   "theme": {
      "dark": {
         "name": "catppuccin-mocha",
         "icon_theme": "Adwaita"
      }
   },
   "telemetry": {
      "system_info": false
   },
   "launcher_window": {
      "opacity": 1,
      "client_side_decorations": {
         "enabled": true,
         "rounding": 12,
         "border_width": 1
      },
      "compact_mode": {
         "enabled": true
      }
   },
   "favorites": [],
   "providers": {
      "@Gelei/store.vicinae.bluetooth": {
         "preferences": {
            "connectionToggleable": true
         }
      },
      "@sovereign/store.vicinae.awww-switcher": {
         "preferences": {
            "wallpaperPath": "~/Pictures/Wallpapers",
            "colorGenTool": "none",
            "gridRows": "4",
            "postProduction": "no",
            "showImageDetails": true,
            "toggleVicinaeSetting": false,
            "transitionDuration": "1",
            "transitionFPS": "60",
            "transitionStep": "255",
            "transitionType": "random",
            "postCommand": "ln -sf ${wallpaper} $HOME/.config/background"
         }
      },
      "applications": {
         "preferences": {
            "defaultAction": "launch",
            "paths": [
               "/home/cherr/.local/share/applications",
               "/home/cherr/.local/share/flatpak/exports/share/applications",
               "/var/lib/flatpak/exports/share/applications",
               "/usr/local/share/applications",
               "/usr/share/applications"
            ],
            "launchPrefix": "uwsm app --"
         },
         "entrypoints": {
            "avahi-discover": {
               "enabled": true
            },
            "bssh": {
               "enabled": true
            },
            "btop": {
               "enabled": true
            },
            "bvnc": {
               "enabled": true
            },
            "limine-snapper-restore": {
               "enabled": true
            },
            "org.cachyos.scx-manager": {
               "enabled": true
            },
            "qv4l2": {
               "enabled": true
            },
            "qvidcap": {
               "enabled": true
            },
            "uuctl": {
               "enabled": true
            },
            "vim": {
               "enabled": true
            },
            "xgps": {
               "enabled": false
            },
            "xgpsspeed": {
               "enabled": false
            },
            "yazi": {
               "enabled": true
            }
         }
      },
      "browser-extension": {
         "enabled": false
      },
      "clipboard": {
         "preferences": {
            "monitoring": true,
            "encryption": false,
            "eraseOnStartup": false,
            "ignorePasswords": false
         },
         "entrypoints": {
            "history": {
               "preferences": {
                  "defaultAction": "copy"
               }
            }
         }
      },
      "core": {
         "entrypoints": {
            "about": {
               "enabled": false
            },
            "documentation": {
               "enabled": false
            },
            "report-bug": {
               "enabled": false
            },
            "sponsor": {
               "enabled": false
            }
         }
      },
      "developer": {
         "enabled": false
      },
      "power": {
         "entrypoints": {
            "hibernate": {
               "enabled": false
            }
         }
      },
      "snippets": {
         "enabled": false
      },
      "system": {
         "entrypoints": {
            "browse-apps": {
               "enabled": false,
               "preferences": {
                  "showHidden": false,
                  "sortAlphabetically": true
               }
            },
            "run": {
               "preferences": {
                  "default-action": "run"
               }
            }
         }
      },
      "theme": {
         "enabled": false
      }
   }
}