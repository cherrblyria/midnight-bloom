// -*- mode: jsonc -*-
{
  "reload_style_on_change": true,
  "height": 30, // Waybar height (to be removed for auto height)
  // "width": 1280, // Waybar width
  "margin": "0",
  "spacing": 0, // Gaps between modules (4px)
  // Choose the order of the modules
  "modules-left": ["hyprland/workspaces", "custom/record"],
  "modules-center": ["clock"],
  "modules-right": [
    "mpris",
    "tray",
    "pulseaudio",
    "bluetooth",
    "network",
    "group/power"
    // "custom/power"
  ],
  // Modules configuration
  "hyprland/workspaces": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "1": "一",
      "2": "二",
      "3": "三",
      "4": "四",
      "5": "五",
      "6": "六",
      "7": "七",
      "8": "八",
      "9": "九",
      "10": "十",
      "11": "十一",
      "12": "十二",
      "13": "十三",
      "14": "十四",
      "15": "十五",
      "16": "十六",
      "17": "十七",
      "18": "十八",
      "19": "十九",
      "20": "二十",
      "21": "二十一",
      "22": "二十二",
      "23": "二十三",
      "24": "二十四",
      "25": "二十五",
      "26": "二十六",
      "27": "二十七",
      "28": "二十八",
      "29": "二十九",
      "30": "三十",
      "default": ""
    },
    "active-only": false,
    "on-scroll-up": "hyprctl dispatch 'hl.workspace({ workspace = \"e+1\" })'",
    "on-scroll-down": "hyprctl dispatch 'hl.workspace({ workspace = \"e-1\" })'"
  },
  "custom/record": {
    "tooltip": false,
    "exec": "mb-record get",
    "on-click": "mb-record",
    "restart-interval": 1
  },
  "clock": {
    "interval": 1,
    "format": "{:%H:%M}",
    "tooltip-format": "{:%A, %B %d %Y, %R:%S}"
  },
  "mpris": {
    "interval": 1,
    "max-length": 50,
    "tooltip": false,
    "format": "{artist} - {title}",
    "format-paused": "<i>{artist} - {title}</i>",
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "on-scroll-up": "mb-vol music-up",
    "on-scroll-down": "mb-vol music-down"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 4
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-bluetooth": "{icon}",
    "format-muted": "",
    "format-icons": {
      "headphone": "",
      "headset": "",
      "phone": "",
      "phone-muted": "",
      "portable": "",
      "car": "",
      "default": ["", ""]
    },
    "tooltip-format": "{icon} {desc} {volume}%",
    "scroll-step": 5,
    "on-click": "footclient --title ft pulsemixer",
    "on-scroll-up": "mb-vol up",
    "on-scroll-down": "mb-vol down"
  },
  "bluetooth": {
    "format": "{status}",
    "format-on": "",
    "format-off": "",
    "format-disabled": "",
    "format-connected": "",
    "tooltip-format": " {controller_alias}  {controller_address}",
    "tooltip-format-connected": " {controller_alias}  {controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": " {device_alias}  {device_address}",
    "tooltip-format-enumerate-connected-battery": " {device_alias}  {device_address}  {device_battery_percentage}%",
    "on-click": "footclient --title ft bluetui"
  },
  "network": {
    "interface": "wlan0",
    "format": "{ifname}",
    "format-wifi": "",
    "format-ethernet": "",
    "format-disconnected": "",
    "tooltip-format": "󰛳 {ifname} via {gwaddr}",
    "tooltip-format-wifi": " {essid} ({signalStrength}%) {ipaddr}",
    "tooltip-format-ethernet": " {ifname}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "footclient nmtui"
  },
  "group/power": {
    "orientation": "horizontal",
    "modules": ["battery", "power-profiles-daemon"],
    "drawer": {
      "transition-left-to-right": false
    }
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "󰁹 Power profile: {profile}\n󱠴 Driver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    }
  },
  "battery": {
    "interval": 1,
    "format": "{icon}{capacity}%",
    "format-full": "",
    "states": {
      "warning": 30,
      "critical": 15,
      "normal": 80,
      "full": 100
    },
    "format-icons": {
      "default": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
      "charging": ["󰢟", "󰢜", "󰂆", "󰂇", "󰂈", "󰢝", "󰂉", "󰢞", "󰂊", "󰂋", "󰂅"]
    }
  },
  "custom/power": {
    "format": "⏻",
    "tooltip": false,
    "on-click": "wlogout -m 0"
  }
}
