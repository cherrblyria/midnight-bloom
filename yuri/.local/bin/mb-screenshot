#!/usr/bin/env bash

dir=$HOME/Pictures/Screenshots
filename="Screenshot_$(date +%Y%m%d_%H%M%S).png"
mode=""
silent=false

while [[ $# -gt 0 ]]; do
  case "$1" in
  -d | --dir)
    dir="$2"
    shift 2
    ;;
  -f | --filename)
    filename="$2"
    shift 2
    ;;
  -s | --silent)
    silent=true
    shift
    ;;
  *)
    mode="$1"
    shift
    ;;
  esac
done

mkdir -p "$dir"
file="$dir/$filename"

notify() { $silent || notify-send "Screenshot saved" "$file" -i "$file"; }

get_mon_geom() {
  mon=$(mmsg get focusing-client 2>/dev/null | jq -r '.monitor // empty')
  [ -z "$mon" ] && mon=$(mmsg get all-monitors | jq -r '.monitors[0].name')
  mmsg get monitor "$mon" | jq -r '"\(.x),\(.y) \(.width)x\(.height)"'
}

case "$mode" in
output)
  geom=$(get_mon_geom)
  [ -z "$geom" ] && exit 1
  grim -g "$geom" - | tee "$file" | wl-copy
  notify
  ;;
window)
  client=$(mmsg get focusing-client 2>/dev/null)
  if echo "$client" | jq -e '.error' >/dev/null 2>&1; then
    geom=$(get_mon_geom)
  else
    geom=$(echo "$client" | jq -r '"\(.x),\(.y) \(.width)x\(.height)"')
  fi
  [ -z "$geom" ] && exit 1
  grim -g "$geom" - | tee "$file" | wl-copy
  notify
  ;;
region)
  pipe=$(mktemp -u).fifo
  mkfifo "$pipe"
  wayfreeze --after-freeze-timeout 100 --after-freeze-cmd "echo > $pipe" &
  wayfreeze_pid=$!
  read -r <"$pipe"
  geometry=$(slurp -d)
  kill "$wayfreeze_pid" 2>/dev/null
  rm -f "$pipe"
  [ -z "$geometry" ] && exit 1
  grim -g "$geometry" - | tee "$file" | wl-copy
  notify
  ;;
esac
