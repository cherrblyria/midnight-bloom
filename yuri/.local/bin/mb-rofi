#!/usr/bin/env bash

pkill rofi || true

case "$1" in
c | clipboard)
  cliphist list | rofi -dmenu -no-show-icons -display-columns 2 -theme mini -p ' ' | cliphist decode | wl-copy
  ;;
e | emoji)
  rofimoji -a copy --use-icons -r '󰞅 ' --selector-args "-theme mini"
  ;;
calc | calculator)
  rofi -modi calc -show calc -theme calculator -no-history -lines 0 -calc-command "echo -n '{result}' | wl-copy"
  ;;
-h | --help | h | help)
  echo "Usage: ${0##*/} [ clipboard | emoji | calc | help ]"
  ;;
*)
  rofi -show drun
  ;;
esac
