#!/usr/bin/env bash

sink="@DEFAULT_SINK@"
source="@DEFAULT_AUDIO_SOURCE@"

_show_music_osd() {
  local raw pct int
  raw=$(playerctl volume)
  pct=$(echo "$raw" | awk '{printf "%d%%", $1 * 100}')
  int=$(echo "$raw" | awk '{printf "%d", $1 * 100}')
  mb-osd Music "$pct" int "$int"
}

case "$1" in
u)
  vol_int=$(wpctl get-volume "$sink" | awk '{printf "%d", $2 * 100}')
  [ "$vol_int" -lt 100 ] && wpctl set-volume "$sink" 5%+
  ;;
d)
  wpctl set-volume "$sink" 5%-
  ;;
uf)
  vol_int=$(wpctl get-volume "$sink" | awk '{printf "%d", $2 * 100}')
  [ "$vol_int" -lt 100 ] && wpctl set-volume "$sink" 1%+
  ;;
df)
  wpctl set-volume "$sink" 1%-
  ;;
m)
  wpctl set-mute "$sink" toggle
  ;;
mm)
  wpctl set-mute "$source" toggle
  if wpctl get-volume "$source" | grep -q MUTED; then
    mb-osd Microphone "Muted"
  else
    mb-osd Microphone "Unmuted"
  fi
  exit 0
  ;;
mu)
  pvol_int=$(playerctl volume | awk '{printf "%d", $1 * 100}')
  [ "$pvol_int" -lt 100 ] && playerctl volume 0.05+
  _show_music_osd
  exit 0
  ;;
md)
  pvol_int=$(playerctl volume | awk '{printf "%d", $1 * 100}')
  [ "$pvol_int" -gt 0 ] && playerctl volume 0.05-
  _show_music_osd
  exit 0
  ;;
esac

vol=$(wpctl get-volume "$sink")
if echo "$vol" | grep -q MUTED; then
  mb-osd Volume "Muted"
else
  pct=$(echo "$vol" | awk '{printf "%d%%", $2*100}')
  int=$(echo "$vol" | awk '{printf "%d", $2*100}')
  mb-osd Volume "$pct" int "$int"
fi
