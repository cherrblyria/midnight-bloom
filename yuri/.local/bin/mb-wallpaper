#!/usr/bin/env bash

WALLPAPER_PATH="$HOME/Pictures/Wallpapers"
THUMB_DIR="$HOME/.cache/wallpaper-thumbs"

function rofi_choose() {
  pkill rofi || true

  local dir
  dir="$(realpath "$1")"
  local find_args=(-type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.gif' -o -iname '*.bmp' -o -iname '*.webp' \))

  mkdir -p "${THUMB_DIR}"

  # Generate missing thumbs in background — don't block rofi
  find -L "${dir}" "${find_args[@]}" -not -name '.*' -not -path '*/.*' -print0 |
    xargs -0 -n1 -P4 bash -c '
      src="$1"
      safe="${src//\//_}"; safe="${safe#_}"
      thumb="'"${THUMB_DIR}"'/${safe}.jpg"
      [[ -f "$thumb" && ! "$src" -nt "$thumb" ]] && exit 0
      magick "$src"[0] -resize 320x180^ -gravity center -extent 320x180 "$thumb" 2>/dev/null
    ' _ &

  # Open rofi immediately — use thumb if ready, else fall back to original
  local selected
  selected=$(
    find -L "${dir}" "${find_args[@]}" -not -name '.*' -not -path '*/.*' -printf '%P\t%p\n' |
      awk -F'\t' '{print (index($1,"/")>0) "\t" $0}' |
      sort -t$'\t' -k1,1n -k2,2 |
      cut -f2- |
      while IFS=$'\t' read -r rel abs; do
        safe="${abs//\//_}"
        safe="${safe#_}"
        thumb="${THUMB_DIR}/${safe}.jpg"
        [[ -f "$thumb" ]] && icon="$thumb" || icon="$abs"
        printf '%s\0icon\x1f%s\n' "$rel" "$icon"
      done |
      rofi -dmenu -p "󰸉 " -show-icons -theme wallpaper
  )

  [[ -z "$selected" ]] && {
    echo ""
    return
  }
  echo "${dir}/${selected}"
}

function resolve_dir() {
  local input="$1"
  if [[ -d "$input" ]]; then
    echo "$input"
  elif [[ -d "${WALLPAPER_PATH}/$input" ]]; then
    echo "${WALLPAPER_PATH}/$input"
  fi
}

function pick_random() {
  local search_path="${1:-$WALLPAPER_PATH}"
  mapfile -t ALL < <(find -L "${search_path}" -type f -not -name '.*' -not -path '*/.*' -print0 | xargs -0 readlink -f | sort -u)
  echo "${ALL[RANDOM % ${#ALL[@]}]}"
}

case "$1" in
r | random)
  SEARCH_PATH="${WALLPAPER_PATH}"
  if [[ -n $2 ]]; then
    SEARCH_PATH="$(resolve_dir "$2")"
    if [[ -z "$SEARCH_PATH" ]]; then
      echo "Subdirectory not found: $2"
      exit 1
    fi
  fi
  SELECTED="$(pick_random "${SEARCH_PATH}")"
  echo "Selected random wallpaper: ${SELECTED}"
  ;;
g | get)
  wall_path=$(readlink -f "$HOME/.cache/wallpaper")
  notify-send -h string:x-canonical-private-synchronous:wallpaper "Wallpaper" "$wall_path"
  echo "$wall_path"
  exit 0
  ;;
-h | --help | h | help)
  echo "Usage: ${0##*/} [ random | get | help ]"
  ;;
*)
  dir="$(resolve_dir "$1")"
  SELECTED="$(rofi_choose "${dir:-$WALLPAPER_PATH}")"
  if [[ -z "${SELECTED}" || ! -f "${SELECTED}" ]]; then
    echo "No wallpaper selected or file does not exist."
    exit 0
  fi
  echo "Selected wallpaper: ${SELECTED}"
  ;;
esac

RESOLVED="$(readlink -f "${SELECTED}")"

# Create symlink to wallpaper in cache directory
notify-send -t 1000 -h string:x-canonical-private-synchronous:wallpaper "Symlinking wallpaper..." "${RESOLVED}"
ln -sf "${RESOLVED}" "$HOME/.cache/wallpaper"

# Set wallpaper using awww
notify-send -t 1000 -h string:x-canonical-private-synchronous:wallpaper "Setting wallpaper..." "${RESOLVED}"
awww img "${RESOLVED}" --transition-type center --transition-duration 1 --transition-fps 48 --transition-step 90

# Generate optimized bg copy for rofi
notify-send -t 1000 -h string:x-canonical-private-synchronous:wallpaper "Caching rofi bg..." "${RESOLVED}"
ROFI_BG_DIR="$HOME/.cache/rofi-bg"
mkdir -p "${ROFI_BG_DIR}"

safe="${RESOLVED//\//_}"
safe="${safe#_}"
CACHED_BG="${ROFI_BG_DIR}/${safe}.jpg"

if [[ ! -f "${CACHED_BG}" || "${RESOLVED}" -nt "${CACHED_BG}" ]]; then
  magick "${RESOLVED}"[0] -resize 700x250^ -gravity center -extent 700x250 -quality 85 "${CACHED_BG}"
fi

ln -sf "${CACHED_BG}" "${ROFI_BG_DIR}/current.jpg"

notify-send -t 1000 -h string:x-canonical-private-synchronous:wallpaper "Done!" "${RESOLVED}"
