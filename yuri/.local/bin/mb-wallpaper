#!/usr/bin/env bash

WALLPAPER_PATH="$HOME/Pictures/Wallpapers"
THUMB_DIR="$HOME/.cache/wallpaper-thumbs"
ROFI_BG_DIR="$HOME/.cache/rofi-bg"

notify() { notify-send -t 10000 -h string:x-canonical-private-synchronous:wallpaper "$@"; }

rofi_choose() {
  pkill rofi 2>/dev/null || true

  local dir
  dir="$(realpath "$1")"
  local find_args=(-type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.gif' -o -iname '*.bmp' -o -iname '*.webp' \))

  mkdir -p "${THUMB_DIR}"

  find -L "${dir}" "${find_args[@]}" -not -name '.*' -not -path '*/.*' -print0 |
    xargs -0 -P4 bash -c '
      for src; do
        safe="${src//\//_}"; safe="${safe#_}"
        thumb="'"${THUMB_DIR}"'/${safe}.jpg"
        [[ -f "$thumb" && ! "$src" -nt "$thumb" ]] && continue
        magick "$src"[0] -resize 320x180^ -gravity center -extent 320x180 "$thumb" 2>/dev/null
      done
    ' _ &

  local selected
  selected=$(
    find -L "${dir}" "${find_args[@]}" -not -name '.*' -not -path '*/.*' -printf '%P\t%p\n' |
      awk -F'\t' '{print (index($1,"/")>0) "\t" $0}' |
      sort -t$'\t' -k1,1n -k2,2 |
      cut -f2- |
      awk -F'\t' -v thumb_dir="${THUMB_DIR}" '
      {
        rel = $1; abs = $2;
        safe = abs;
        gsub("/", "_", safe);
        sub("^_", "", safe);
        thumb = thumb_dir "/" safe ".jpg";

        # Always pointing to the thumb path prevents Rofi from freezing on massive raw images
        printf "%s\0icon\x1f%s\n", rel, thumb
      }' |
      rofi -dmenu -p "󰸉 " -show-icons -theme wallpaper
  )

  [[ -z "$selected" ]] && return
  echo "${dir}/${selected}"
}

resolve_dir() {
  local input="$1"
  [[ -d "$input" ]] && echo "$input" && return
  [[ -d "${WALLPAPER_PATH}/$input" ]] && echo "${WALLPAPER_PATH}/$input"
}

pick_random() {
  local search_path="${1:-$WALLPAPER_PATH}"
  find -L "${search_path}" -type f -not -name '.*' -not -path '*/.*' | shuf -n 1 | xargs readlink -f
}

set_wallpaper() {
  local resolved
  resolved="$(readlink -f "$1")"

  notify "Symlinking wallpaper..." "${resolved}"
  ln -sf "${resolved}" "$HOME/.cache/wallpaper"

  notify "Setting wallpaper..." "${resolved}"
  awww img "${resolved}" --transition-type fade --transition-duration 1 --transition-fps 30

  notify "Caching rofi bg..." "${resolved}"
  mkdir -p "${ROFI_BG_DIR}"

  local safe="${resolved//\//_}"
  safe="${safe#_}"
  local cached="${ROFI_BG_DIR}/${safe}.jpg"

  (
    if [[ ! -f "${cached}" || "${resolved}" -nt "${cached}" ]]; then
      magick "${resolved}"[0] -resize 700x250^ -gravity center -extent 700x250 -quality 85 "${cached}"
    fi
    ln -sf "${cached}" "${ROFI_BG_DIR}/current.jpg"
  ) &

  notify -t 1000 "Done!" "${resolved}"
}

case "${1:-}" in
r | random)
  search_path="${WALLPAPER_PATH}"
  if [[ -n $2 ]]; then
    search_path="$(resolve_dir "$2")"
    [[ -z "$search_path" ]] && echo "Subdirectory not found: $2" && exit 1
  fi
  selected="$(pick_random "${search_path}")"
  echo "Selected random wallpaper: ${selected}"
  ;;
g | get)
  wall_path="$(readlink -f "$HOME/.cache/wallpaper")"
  notify-send -h string:x-canonical-private-synchronous:wallpaper "Wallpaper" "$wall_path"
  echo "$wall_path"
  exit 0
  ;;
h | help | -h | --help)
  echo "Usage: ${0##*/} [ random | get | help ]"
  exit 0
  ;;
*)
  dir="$(resolve_dir "${1:-}")"
  selected="$(rofi_choose "${dir:-$WALLPAPER_PATH}")"
  [[ -z "${selected}" ]] && echo "No wallpaper selected." && exit 0
  echo "Selected wallpaper: ${selected}"
  ;;
esac

set_wallpaper "${selected}"
