#!/usr/bin/env bash

WALLPAPER_PATH="$HOME/Pictures/Wallpapers"
CACHE_DIR="$HOME/.cache/midnight-bloom"
THUMB_DIR="${CACHE_DIR}/rofi-wallthumbs"
ROFI_BG_DIR="${CACHE_DIR}/rofi-bg"

EXTENSIONS=("-iname" "*.jpg" "-o" "-iname" "*.jpeg" "-o" "-iname" "*.png" "-o" "-iname" "*.gif" "-o" "-iname" "*.webp" "-o" "-iname" "*.bmp")

notify() { notify-send -t 3000 -h string:x-canonical-private-synchronous:wallpaper "$@"; }

get_safe_name() {
  local name="${1//\//_}"
  echo "${name#_}"
}

make_thumb() {
  local src="$1" dest="$2" size="$3"

  [[ -f "$dest" && ! "$src" -nt "$dest" ]] && return

  local opts=""
  [[ "${src,,}" == *.gif ]] && opts="[page=0]"

  vipsthumbnail "${src}${opts}" --vips-concurrency=4 --size="${size}" --crop -o "${dest}[Q=85]" 2>/dev/null
}
export -f make_thumb
export -f get_safe_name

rofi_choose() {
  pkill rofi 2>/dev/null
  local dir
  dir="$(realpath "$1")"
  mkdir -p "${THUMB_DIR}"

  (
    find -L "$dir" -type f \( "${EXTENSIONS[@]}" \) -not -path '*/.*' -print0 |
    while IFS= read -r -d $'\0' img; do
      make_thumb "$img" "${THUMB_DIR}/$(get_safe_name "$img").jpg" "320x180"
    done
  ) &

  local selected
  selected=$(
    find -L "$dir" -type f \( "${EXTENSIONS[@]}" \) -not -path '*/.*' -printf "%P\n" |
    sort |
    awk -v dir="$dir" -v tdir="${THUMB_DIR}" '{
      abs_path = dir "/" $0
      safe_name = abs_path
      gsub("/", "_", safe_name)
      sub("^_", "", safe_name)
      printf "%s\0icon\x1f%s/%s.jpg\n", $0, tdir, safe_name
    }' |
    rofi -dmenu -p "󰸉 " -show-icons -theme wallpaper
  )

  [[ -n "$selected" ]] && echo "${dir}/${selected}"
}

set_wallpaper() {
  local img
  img="$(readlink -f "$1")"
  [[ -z "$img" || ! -f "$img" ]] && return

  notify -i "$img" "Setting wallpaper..." "${img##*/}"
  awww img "$img" --transition-type simple --transition-fps 60 --transition-step 10

  (
    mkdir -p "${ROFI_BG_DIR}"
    local bg_cache
    bg_cache="${ROFI_BG_DIR}/$(get_safe_name "$img").jpg"

    make_thumb "$img" "$bg_cache" "700x250"
    ln -sf "$bg_cache" "${ROFI_BG_DIR}/current.jpg"
  ) &

  notify -t 1500 -i "$img" "Wallpaper updated!" "${img##*/}"
}

cmd="${1:-}"
arg="${2:-}"

case "$cmd" in
  r | random)
    target_dir="${WALLPAPER_PATH}"
    [[ -n "$arg" ]] && target_dir="${WALLPAPER_PATH}/${arg}"
    [[ ! -d "$target_dir" ]] && echo "Directory not found: $target_dir" && exit 1

    selected=$(find -L "$target_dir" -type f \( "${EXTENSIONS[@]}" \) -not -path '*/.*' | shuf -n 1)
    ;;
  g | get)
    wall_path=$(awww query | grep -oP 'currently displaying: image: \K.*')
    [[ -z "$wall_path" || ! -f "$wall_path" ]] && echo "No wallpaper set" && exit 1
    notify -i "$wall_path" "Current Wallpaper" "$wall_path"
    echo "$wall_path"
    exit 0
    ;;
  h | help | -h | --help)
    echo "Usage: ${0##*/} [ random <dir> | get | help ]"
    exit 0
    ;;
  *)
    target_dir="${WALLPAPER_PATH}"
    [[ -d "$cmd" ]] && target_dir="$(realpath "$cmd")"
    [[ -d "${WALLPAPER_PATH}/$cmd" ]] && target_dir="${WALLPAPER_PATH}/$cmd"

    selected=$(rofi_choose "$target_dir")
    [[ -z "$selected" ]] && exit 0
    ;;
esac

set_wallpaper "$selected"
